# Database Configuration
POSTGRES_USER=cfbot
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_DB=confluence_chatbot

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# Azure OpenAI Configuration (GPT-5.1)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-5.1
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# DingTalk Configuration
DINGTALK_APP_KEY=your_dingtalk_app_key_here
DINGTALK_APP_SECRET=your_dingtalk_app_secret_here

# JWT Configuration
JWT_SECRET=your_random_jwt_secret_key_here_min_32_chars

# Application Configuration
ENVIRONMENT=production
CORS_ORIGINS=https://cf.rocktor.shop

# Frontend Configuration
VITE_API_URL=https://cf.rocktor.shop/api
VITE_WS_URL=wss://cf.rocktor.shop/api/chat/ws
